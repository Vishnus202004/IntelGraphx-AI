# General FastAPI Settings
PROJECT_NAME="IntelGraph AI"
API_V1_STR="/api/v1"

# Database Configuration
DATABASE_URL="sqlite+aiosqlite:///./intelgraph.db"

# Security Configurations
SECRET_KEY="generate-a-secure-key-using-openssl-rand-hex-32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (SMTP) Configuration
# SMTP Settings (Optional, for email alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_password

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGCHAIN_PROJECT="IntelGraph-AI"

# External APIs
NEWS_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY=""

# LangSmith Monitoring
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="intelgraph-ai"
